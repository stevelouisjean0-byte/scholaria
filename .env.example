# =============================================================================
# Scholaria — Environment Configuration
# Copy to `.env.local` (dev) or set these as platform secrets (prod).
# NEVER commit real values. Agent IDs are sensitive backend identifiers.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic / Claude Managed Agents
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7
ANTHROPIC_FAST_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Claude Managed Agent IDs — full IDs from Claude Console
# Replace the trailing dots with the full agent identifier strings.
# -----------------------------------------------------------------------------
AGENT_LEAD_INTAKE=agent_...ZcfjFq
AGENT_PROJECT_SCOPING=agent_...wo3XuX
AGENT_ORCHESTRATOR=agent_011Ca2wNP6CFLzFhtALmv48G
AGENT_PROFESSIONAL_EDITOR=agent_...4fTa8Z
AGENT_RESEARCH_SUPPORT=agent_...8vtRfU
AGENT_RESEARCH_INTELLIGENCE=agent_014F6nMA5TnSZqpFzjb1RThr

AGENT_PRICING_PAYMENT_PRIMARY=agent_...yDaoBs
AGENT_PRICING_PAYMENT_BACKUP=agent_011Ca2vSqAaLQWzNPYpt39aX

AGENT_QA_FINAL_PRIMARY=agent_...j7Wh6V
AGENT_QA_FINAL_BACKUP=agent_011Ca2uhRemJM9uy78bsoBJ6

AGENT_CLIENT_SUPPORT=agent_...ZnCMs3
AGENT_SEO_GROWTH=agent_011Ca4eZrexnqhXvik84iJrH
AGENT_SURVEY_COMPLETION=agent_011Ca5Qz4b7UFpze1TgXWkLJ

# -----------------------------------------------------------------------------
# Database — Supabase (Postgres)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://user:pass@host:5432/scholaria
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# -----------------------------------------------------------------------------
# Redis (queue + cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://default:password@host:6379

# -----------------------------------------------------------------------------
# Authentication — Clerk
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Stripe billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

STRIPE_PRICE_GRADUATE_MONTHLY=price_...
STRIPE_PRICE_GRADUATE_ANNUAL=price_...
STRIPE_PRICE_DOCTORAL_MONTHLY=price_...
STRIPE_PRICE_DOCTORAL_ANNUAL=price_...
STRIPE_PRICE_DISSERTATION_MONTHLY=price_...
STRIPE_PRICE_DISSERTATION_ANNUAL=price_...
STRIPE_PRICE_UNIVERSITY=price_...

# -----------------------------------------------------------------------------
# Storage — secure encrypted uploads (S3-compatible)
# -----------------------------------------------------------------------------
S3_ENDPOINT=https://...
S3_REGION=us-east-1
S3_BUCKET=scholaria-uploads
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
UPLOAD_ENCRYPTION_KEY=base64:...

# -----------------------------------------------------------------------------
# Email / notifications
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
NOTIFY_FROM=Scholaria Concierge <concierge@scholaria.ai>
NOTIFY_REPLY_TO=support@scholaria.ai

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=info
NODE_ENV=development

# -----------------------------------------------------------------------------
# Public app config
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://scholaria.ai
NEXT_PUBLIC_APP_NAME=Scholaria
